    </owl:Class>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Ruta -->

    <owl:Class rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Ruta">
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Vehiculo"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Transportista -->

