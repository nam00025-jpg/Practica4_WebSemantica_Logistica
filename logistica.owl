    </owl:Class>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#UbicaciónDestino -->

    <owl:Class rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#UbicaciónDestino">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Ubicación"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#UbicaciónOrigen -->

    <owl:Class rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#UbicaciónOrigen">
