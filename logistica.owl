<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3/"
     xml:base="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:untitled-ontology-3="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->

    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#asignadaA -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#asignadaA">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#tieneRutaAsignada"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Ruta"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Transportista"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#conduceVehículo -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#conduceVehículo">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#esConducidoPor"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Transportista"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Vehiculo"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#dirigidoA -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#dirigidoA">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Envío"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Destinatario"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#esConducidoPor -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#esConducidoPor">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#esGeneradoPor -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#esGeneradoPor">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#generaEnvío"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#esTransportadoPor -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#esTransportadoPor">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#transporta"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#estaUbicadoEn -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#estaUbicadoEn">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Envío"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Ubicación"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#finalizaEn -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#finalizaEn">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Ruta"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Ubicación"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#generaEnvío -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#generaEnvío">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Remitente"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Envío"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#iniciaEn -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#iniciaEn">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Ruta"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Ubicación"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#procesadoEn -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#procesadoEn">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Envío"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Infraestructura"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#registraEstado -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#registraEstado">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Envío"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#EstadoEnvio"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#reparteEnvio -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#reparteEnvio">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#tieneClienteDestino -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#tieneClienteDestino">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#tieneRutaAsignada -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#tieneRutaAsignada">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#transporta -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#transporta">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Vehiculo"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Envío"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#fechaRegistro -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#fechaRegistro">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Envío"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#identificadorAlfanumerico -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#identificadorAlfanumerico">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Envío"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#pesoKg -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#pesoKg">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Envío"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#telefonoContacto -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#telefonoContacto">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Persona"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


