    </owl:Class>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Vehiculo -->

    <owl:Class rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Vehiculo"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Caja_libros -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Caja_libros">
        <rdf:type rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Paquete"/>
        <untitled-ontology-3:dirigidoA rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Natalia_Cliente"/>
        <untitled-ontology-3:identificadorAlfanumerico>1234</untitled-ontology-3:identificadorAlfanumerico>
        <untitled-ontology-3:pesoKg rdf:datatype="http://www.w3.org/2001/XMLSchema#float">5.88</untitled-ontology-3:pesoKg>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Empresa_Amazon -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Empresa_Amazon">
        <rdf:type rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Remitente"/>
        <untitled-ontology-3:generaEnvío rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Caja_libros"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Furgoneta_01 -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Furgoneta_01">
        <rdf:type rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Vehiculo"/>
        <untitled-ontology-3:transporta rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Caja_libros"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Natalia_Cliente -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Natalia_Cliente">
        <rdf:type rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Destinatario"/>
    </owl:NamedIndividual>
    


