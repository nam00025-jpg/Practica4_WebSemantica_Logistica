    </owl:Class>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Persona -->

    <owl:Class rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Persona">
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Ruta"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Ubicación"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Vehiculo"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Remitente -->

    <owl:Class rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Remitente">
