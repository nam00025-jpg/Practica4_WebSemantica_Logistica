    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Ubicación -->

    <owl:Class rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Ubicación">
