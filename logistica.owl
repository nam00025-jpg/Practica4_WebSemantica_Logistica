     -->

    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Carta -->

    <owl:Class rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Carta">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Envío"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Paquete"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#CentroLogistico -->

    <owl:Class rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#CentroLogistico">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Infraestructura"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Cliente -->

    <owl:Class rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Cliente">
